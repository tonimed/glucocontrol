root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
max_line_length = 120
trim_trailing_whitespace = true

[*.kt]
# Permite PascalCase en funciones anotadas con @Composable (convención de Jetpack Compose)
ktlint_function_naming_ignore_when_annotated_with = Composable
ktlint_code_style = intellij_idea
